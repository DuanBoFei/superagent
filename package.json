{
  "name": "superagent",
  "version": "0.1.0",
  "private": true,
  "description": "Model-free, MIT-licensed CLI coding agent",
  "type": "module",
  "bin": {
    "superagent": "./bin/superagent.js"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:visual": "playwright test",
    "test:visual:update": "playwright test --update-snapshots",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src/ tests/",
    "lint:css": "stylelint \"packages/web/src/**/*.css\" \"tests/web/*.css\" --allow-empty-input",
    "dev:web": "pnpm -C packages/web dev",
    "build:web": "pnpm -C packages/web build"
  },
  "keywords": [
    "ai-agent",
    "cli",
    "coding-agent",
    "deepseek"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "better-sqlite3": "^12.10.0",
    "cosmiconfig": "^9.0.2",
    "diff": "^9.0.0",
    "diff-match-patch": "^1.0.5",
    "marked": "^18.0.5",
    "pino": "^10.3.1",
    "zod": "^3.23"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.61.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^25.9.3",
    "@vitest/coverage-v8": "2",
    "axe-core": "^4.12.1",
    "biome": "^0.3.3",
    "jsdom": "^29.1.1",
    "stylelint": "^17.13.0",
    "stylelint-config-standard": "^40.0.0",
    "tsx": "^4.22.4",
    "typescript": "^5.5",
    "vitest": "^2"
  }
}
