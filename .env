# SuperAgent Environment Configuration
# Copy this to .env.local and fill in your real values.
# This file is safe to commit (placeholders only).

# DeepSeek API
SUPERAGENT_API_KEY=sk-your-api-key-here
SUPERAGENT_BASE_URL=https://api.deepseek.com
SUPERAGENT_MODEL=deepseek-v4-pro
SUPERAGENT_FALLBACK_MODEL=deepseek-v4-flash
SUPERAGENT_FALLBACK_BASE_URL=https://api.deepseek.com

# WebSearch — DuckDuckGo (free, no API key needed)
SUPERAGENT_WEB_SEARCH_PROVIDER=duckduckgo

# Runtime
SUPERAGENT_MAX_TURNS=50
