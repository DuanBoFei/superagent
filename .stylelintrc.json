{
  "$schema": "https://json.schemastore.org/stylelintrc.json",
  "extends": ["stylelint-config-standard"],
  "rules": {
    "color-named": "never",
    "color-no-hex": [true, {"severity": "warning"}],
    "color-function-notation": "modern",
    "alpha-value-notation": "number",
    "hue-degree-notation": "number",
    "length-zero-no-unit": true,
    "shorthand-property-no-redundant-values": true,
    "declaration-block-no-redundant-longhand-properties": true,
    "number-max-precision": 3,
    "value-keyword-case": [
      "lower",
      {
        "camelCaseSvgKeywords": true,
        "ignoreProperties": ["font-family", "font"]
      }
    ],
    "selector-class-pattern": [
      "^[a-z]([a-z0-9-]+)?(__[a-z]([a-z0-9-]+)?)?(--[a-z]([a-z0-9-]+)?)?$",
      {
        "message": "Expected class selector to be kebab-case or BEM format",
        "resolveNestedSelectors": true
      }
    ],
    "declaration-property-value-disallowed-list": {
      "/^border$/": ["/^#[0-9a-fA-F]{3,8}(?!.*var.*)/"],
      "/^background$/": ["/^#[0-9a-fA-F]{3,8}(?!.*var.*)/"]
    }
  },
  "overrides": [
    {
      "files": ["**/terminal*.css"],
      "rules": {
        "color-no-hex": null,
        "declaration-property-value-disallowed-list": {}
      }
    },
    {
      "files": ["**/design-tokens.css"],
      "rules": {
        "color-no-hex": null
      }
    }
  ]
}
